{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EKO",
  "version": "0.4.11",
  "identifier": "com.reactivepixels.eko",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EKO",
        "width": 1200,
        "height": 800,
        "minWidth": 940,
        "minHeight": 700,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 20 },
        "shadow": true
      },
      {
        "label": "mini",
        "title": "EKO Mini",
        "width": 520,
        "height": 96,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: stream: data: blob: https://asset.localhost; media-src 'self' asset: stream: data: blob: https://asset.localhost; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "__comment": "DEV pubkey — generated by `npm run tauri signer generate -w dev-keys/updater_dev.key`. Swap for the real prod pubkey before shipping. Private key stays in dev-keys/updater_dev.key (gitignored) locally and in the TAURI_SIGNING_PRIVATE_KEY CI secret for releases.",
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCQTgxNjY2RUM4QTQ1OTQKUldTVVJZcnNaaGFveSsvTUpHazM1dUFMSmdqTUp4RE9lclBWSUhnOUtzWE41OFREalp1TmswdUsK",
      "endpoints": ["https://github.com/reactivepixels/eko/releases/latest/download/latest.json"]
    }
  }
}
